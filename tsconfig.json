{
    "include": [
        "./src/**/*"
    ],
    "compilerOptions": {
        "strict": true,
        "esModuleInterop": true,
        "allowSyntheticDefaultImports": true,
        "forceConsistentCasingInFileNames": false,
        "lib": [
            "dom",
            "es2020"
        ],
        "jsx": "react-jsx",
        "types": ["node"],
        "typeRoots": ["./src/types", "./node_modules/@types"],
        "moduleResolution": "node",
        "module": "esnext",
        "skipLibCheck": true,
        "resolveJsonModule": true,
        "isolatedModules": true,
        "noEmit": true
    }
}